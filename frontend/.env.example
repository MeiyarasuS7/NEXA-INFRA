# ============================= API CONFIGURATION =============================
# Example production value: https://api.your-domain.com/api
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_API_TIMEOUT=30000

# ============================= AUTHENTICATION =============================
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_JWT_SECRET=your-jwt-secret-key

# ============================= APPLICATION =============================
VITE_APP_NAME=NEXA INFRA
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# ============================= FEATURES =============================
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_AI_CHATBOT=true
VITE_ENABLE_REAL_TIME_CHAT=true
VITE_ENABLE_FILE_UPLOADS=true

# ============================= AI CHATBOT (GROQ) =============================
# Get your API key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_MODEL=llama-3.3-70b-versatile
VITE_CHATBOT_MAX_TOKENS=1024
VITE_CHATBOT_TEMPERATURE=0.7

# ============================= FILE UPLOAD =============================
VITE_MAX_FILE_SIZE_MB=10
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# ============================= WEBSOCKET =============================
# Example production value: wss://api.your-domain.com/ws
VITE_WS_BASE_URL=wss://api.your-domain.com/ws

# ============================= ANALYTICS =============================
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=

# ============================= LOGGING =============================
VITE_LOG_LEVEL=development
